<view class="page-container">
  <scroll-view scroll-x class="category-tabs">
    <view class="category-tab {{activeCategoryId === '' ? 'active' : ''}}" bind:tap="onCategoryTap" data-id="">
      全部
    </view>
    <view
      class="category-tab {{activeCategoryId === item._id ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="_id"
      bind:tap="onCategoryTap"
      data-id="{{item._id}}"
    >
      {{item.name}}
    </view>
  </scroll-view>

  <article-card wx:for="{{articles}}" wx:key="_id" article="{{item}}" />
  <empty-state wx:if="{{!articles.length && !loading}}" text="该分类下暂无文章" />
</view>
