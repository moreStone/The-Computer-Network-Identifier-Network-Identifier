<view class="page-container" wx:if="{{article}}">
  <view class="article-header">
    <text class="article-title">{{article.title}}</text>
    <view class="article-meta">
      <text>{{article.publishDate}}</text>
      <text>{{article.viewCount}} 阅读</text>
    </view>
  </view>
  <view class="article-body">
    <rich-text nodes="{{article.content}}" />
  </view>
  <view class="article-tags" wx:if="{{article.tags.length}}">
    <text class="tag" wx:for="{{article.tags}}" wx:key="*this">{{item}}</text>
  </view>
</view>

<view class="comment-section">
  <view class="comment-title">评论 ({{comments.length}})</view>
  <comment-item wx:for="{{comments}}" wx:key="_id" comment="{{item}}" />
  <empty-state wx:if="{{!comments.length && !loading}}" text="暂无评论" />
  <comment-input bind:submit="onCommentSubmit" />
</view>
