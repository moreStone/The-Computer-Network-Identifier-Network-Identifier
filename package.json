{
  "name": "personal-blog-miniprogram",
  "version": "1.0.0",
  "private": true,
  "description": "Personal blog WeChat Mini Program with cloud development",
  "scripts": {
    "lint": "eslint . --ext .js,.wxs",
    "lint:fix": "eslint . --ext .js,.wxs --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --config jest.config.js",
    "test:component": "jest --config jest.component.config.js",
    "test:all": "npm run test && npm run test:component",
    "prepare": "husky install",
    "upload:preview": "node scripts/upload-preview.js",
    "upload:production": "node scripts/upload-production.js",
    "init:db": "node scripts/init-database.js"
  },
  "devDependencies": {
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-prettier": "^4.2.1",
    "prettier": "^2.8.8",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "@commitlint/cli": "^18.4.0",
    "@commitlint/config-conventional": "^18.4.0",
    "jest": "^29.7.0",
    "miniprogram-simulate": "^1.5.9",
    "miniprogram-automator": "^0.12.0",
    "miniprogram-ci": "^2.1.22",
    "babel-jest": "^29.7.0",
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0"
  }
}
